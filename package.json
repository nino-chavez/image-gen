{
  "name": "@nino-tools/image-gen",
  "version": "1.1.0",
  "description": "AI-powered image generation and HTML-to-PNG rendering with style systems and optimization",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./providers": "./src/providers/index.js",
    "./templates": "./src/templates/engine.js",
    "./styles": "./src/styles/index.js"
  },
  "bin": {
    "image-gen": "./src/cli.js"
  },
  "files": [
    "src/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "generate": "node src/cli.js",
    "test": "node tests/run.js",
    "render": "node src/cli.js render",
    "template": "node src/cli.js template"
  },
  "keywords": [
    "ai",
    "image-generation",
    "html-to-png",
    "screenshot",
    "openrouter",
    "gemini",
    "dall-e",
    "playwright",
    "social-media",
    "template"
  ],
  "author": "Nino Chavez",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nino-chavez/image-gen.git"
  },
  "homepage": "https://github.com/nino-chavez/image-gen#readme",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "openai": "^4.70.0",
    "ora": "^8.0.0",
    "playwright": "^1.58.2",
    "sharp": "^0.34.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
